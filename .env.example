# Buzzora — environment configuration
# Copy to .env.local and fill in real values. Never commit real keys.

# Canonical site URL (used for metadata / schema)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# WhatsApp business number in international format, digits only (e.g. 91XXXXXXXXXX).
# Turns on the floating "Chat with us" button AND the WhatsApp checkout, which
# sends each order straight to this number. Works on static hosting (no server).
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Business contact email — used by the wholesale form and as an order fallback.
NEXT_PUBLIC_CONTACT_EMAIL=

# Turn on server-verified online card/UPI payments (needs a server host like
# Vercel — not GitHub Pages). Set to "razorpay" and fill the keys below.
NEXT_PUBLIC_PAYMENT_PROVIDER=
PAYMENT_PROVIDER=

# Razorpay (if payments enabled). Get keys at dashboard.razorpay.com.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Stripe (if PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Analytics (optional — only loaded when set)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
