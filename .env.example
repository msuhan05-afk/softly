# Buzzora — environment configuration
# Copy to .env.local and fill in real values. Never commit real keys.

# Canonical site URL (used for metadata / schema)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# WhatsApp business number in international format, digits only (e.g. 91XXXXXXXXXX).
# The floating "Chat with us" button only appears when this is set.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Business contact email (wholesale enquiry form)
NEXT_PUBLIC_CONTACT_EMAIL=

# Payment provider: "razorpay" (India-first) or "stripe" (international).
# Leave empty for manual/COD order confirmation.
PAYMENT_PROVIDER=

# Razorpay (if PAYMENT_PROVIDER=razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Stripe (if PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Analytics (optional — only loaded when set)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
